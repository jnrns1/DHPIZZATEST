{
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    },
    {
      "source": "/:path((?:.*\\.(?:jpg|jpeg|gif|png|webp|svg|ico|css|js|woff|woff2|ttf|eot))|(?:fonts/.*))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/story",
      "destination": "/story.html",
      "statusCode": 301
    },
    {
      "source": "/menu",
      "destination": "/menu.html",
      "statusCode": 301
    },
    {
      "source": "/locations",
      "destination": "/locations.html",
      "statusCode": 301
    },
    {
      "source": "/reserve",
      "destination": "/reserve.html",
      "statusCode": 301
    },
    {
      "source": "/careers",
      "destination": "/careers.html",
      "statusCode": 301
    },
    {
      "source": "/contact",
      "destination": "/contact.html",
      "statusCode": 301
    }
  ]
}
